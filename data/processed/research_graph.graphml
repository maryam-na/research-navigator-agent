    <node id="statement:stmt_89f7c15bc75d">
      <data key="d0">statement</data>
      <data key="d2">stmt_89f7c15bc75d</data>
      <data key="d1">paper_04</data>
      <data key="d3">paper_04:chunk_0018</data>
      <data key="d4">method</data>
      <data key="d5">We use recall rather than precision because ground-truth annotations in biological databases are known to be incomplete—not all correct an- notations have been curated, so a prediction absent from the ground truth is not necessarily wrong, making precision less reliable.</data>
      <data key="d6">We use recall rather than precision because ground-truth annotations in biological databases are known to be incomplete—not all correct an- notations have been curated, so a prediction absent from the ground truth is not necessarily wrong, making precision less reliable.</data>
      <data key="d7">rule:we use</data>
      <data key="d8">4</data>
    </node>
    <node id="method:stmt_89f7c15bc75d">
      <data key="d0">method</data>
      <data key="d2">stmt_89f7c15bc75d</data>
      <data key="d1">paper_04</data>
      <data key="d3">paper_04:chunk_0018</data>
      <data key="d5">We use recall rather than precision because ground-truth annotations in biological databases are known to be incomplete—not all correct an- notations have been curated, so a prediction absent from the ground truth is not necessarily wrong, making precision less reliable.</data>
